# ---- Site ----
NEXT_PUBLIC_SITE_NAME="Ur Gay Now"
NEXT_PUBLIC_SITE_URL="https://urgaynow.com"

# ---- Database (Supabase Postgres) ----
# Runtime / app: Supabase POOLER (port 6543). Vercel CAN reach the
# pooler host but CANNOT reach the direct :5432 host, so on Vercel
# you MUST use the pooler (never the direct :5432 connection).
# The pooler MUST be in SESSION mode (Supabase dashboard ->
# Settings -> Database -> Connection pooler); Transaction mode causes
# Prisma "prepared statement already exists / does not exist" (PgBouncer).
DDATABASE_URL="postgresql://postgres.xxiqfoghxbozycuxsqpr:Urgaynow2024@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=20"
# Migrations / schema changes: the direct connection (port 5432) when reachable.
DIRECT_URL="postgresql://postgres:Urgaynow2024@db.xxiqfoghxbozycuxsqpr.supabase.co:5432/postgres?sslmode=require"

# ---- Admin auth ----
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"
AUTH_SECRET="change-me-to-a-long-random-string-please-32chars+"

