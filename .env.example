# ---- Database (Supabase Postgres) ----
# Create a Supabase project, then use the Postgres connection string from
# Settings -> Database -> URI (use the DIRECT connection for migrations).
# Format: postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:Urgaynow2024@db.wloygmjdziensgddilzz.supabase.co:5432/postgres"
# Or, for the direct connection (for migrations):
# DATABASE_URL="postgresql://postgres:Urgaynow2024@db.wloygmjdziensgddilzz.supabase.co:5432/postgres"
# ---- Admin auth ----
ADMIN_USERNAME="Urgaynowadmin"
ADMIN_PASSWORD="change-me"
# A long random string used to sign the session cookie.
AUTH_SECRET="change-me-to-a-long-random-string-please-32chars+"

# ---- Image uploads ----
# Optional. If set, uploads use Vercel Blob (persistent on Vercel).
# If left empty, uploads are saved to ./public/uploads (local dev only).
BLOB_READ_WRITE_TOKEN=""
