// Prisma schema configured for Supabase (PostgreSQL).
// - Runtime: DATABASE_URL -> Supabase Transaction Pooler (port 6543)
// - Migrations: DIRECT_URL -> Supabase direct connection (port 5432)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Staff {
  id             String   @id @default(cuid())
  name           String
  vrchatUsername String   @unique
  rank           String   @default("Member")
  bio            String   @default("")
  photoUrl       String   @default("")
  socials        String   @default("[]") // JSON array of { label, url }
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Partner {
  id          String   @id @default(cuid())
  name        String
  logoUrl     String   @default("")
  description String   @default("")
  links       String   @default("[]") // JSON array of { label, url }
  tag         String   @default("Partner") // Partner | Affiliate | Friend Community
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Announcement {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  excerpt         String   @default("")
  content         String   @default("") // Markdown
  coverImage      String   @default("")
  published       Boolean  @default(true)
  publishedAt     DateTime @default(now())
  discordMessageId String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Event {
  id            String    @id @default(cuid())
  title         String
  description   String    @default("") // Markdown
  location      String    @default("")
  vrchatWorldUrl String   @default("")
  coverImage    String    @default("")
  startDateTime DateTime
  endDateTime   DateTime?
  published     Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Rule {
  id        String @id @default(cuid())
  category  String @default("General")
  title     String
  content   String @default("") // Markdown
  sortOrder Int    @default(0)
}

model Guide {
  id        String @id @default(cuid())
  category  String @default("General")
  question  String
  answer    String @default("") // Markdown
  sortOrder Int    @default(0)
}

model Link {
  id        String @id @default(cuid())
  label     String
  url       String
  icon      String @default("link") // emoji or icon name
  sortOrder Int    @default(0)
}

model GalleryImage {
  id              String    @id @default(cuid())
  title           String
  description     String    @default("")
  imageUrl        String
  status          String    @default("APPROVED") // PENDING | APPROVED | REJECTED
  submitterName   String    @default("")
  rejectionReason String    @default("")
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())
}

model GroupPhoto {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  imageUrl    String
  bannerUrl   String   @default("")
  rules       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  key       String   @id
  value     String   @default("")
  updatedAt DateTime @updatedAt
}

model ShopDesign {
  id          String   @id @default(cuid())
  name        String
  description String?
  creator     String?
  category    String?
  imageUrl    String
  imageAlt    String?
  galleryUrls String[] @default([])
  featured    Boolean  @default(false)
  published   Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// System Status / Status page
// ---------------------------------------------------------------------------

model StatusService {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String   @default("")
  category       String   @default("Core") // Core | Payments | Platform
  status         String   @default("operational")
  autoManaged    Boolean  @default(true)
  manualOverride Boolean  @default(false)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  healthChecks   HealthCheck[]
  incidents      IncidentService[]
  maintenances   MaintenanceService[]
}

model Incident {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  status      String   @default("investigating") // investigating | identified | monitoring | resolved
  impact      String   @default("minor") // none | minor | major | critical
  published   Boolean  @default(true)
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updates     IncidentUpdate[]
  services    IncidentService[]
}

model IncidentUpdate {
  id         String   @id @default(cuid())
  incidentId String
  message    String
  status     String   @default("investigating")
  createdAt  DateTime @default(now())
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
}

model IncidentService {
  incidentId String
  serviceId  String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  service    StatusService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([incidentId, serviceId])
}

model Maintenance {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  status      String   @default("scheduled") // scheduled | in_progress | completed
  startAt     DateTime
  endAt       DateTime
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updates     MaintenanceUpdate[]
  services    MaintenanceService[]
}

model MaintenanceUpdate {
  id           String     @id @default(cuid())
  maintenanceId String
  message      String
  createdAt    DateTime   @default(now())
  maintenance  Maintenance @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)

  @@index([maintenanceId])
}

model MaintenanceService {
  maintenanceId String
  serviceId     String
  maintenance    Maintenance @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)
  service        StatusService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([maintenanceId, serviceId])
}

model HealthCheck {
  id         String   @id @default(cuid())
  serviceId  String
  ok         Boolean
  status     String   @default("operational")
  latencyMs  Int?
  detail      String   @default("")
  checkedAt  DateTime @default(now())
  service    StatusService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, checkedAt])
}

model StatusSubscriber {
  id              String   @id @default(cuid())
  email           String?
  discordWebhook  String?
  pushEndpoint    String? // Web Push subscription endpoint (optional)
  pushP256dh      String?
  pushAuth        String?
  verified        Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@unique([email])
}
