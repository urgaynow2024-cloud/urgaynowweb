# ---- Site ----
NEXT_PUBLIC_SITE_NAME="Ur Gay Now"
NEXT_PUBLIC_SITE_URL="https://urgaynow.com"

# ---- Database (Supabase Postgres) ----
# Runtime / app: Supabase POOLER (port 6543). Vercel CAN reach the
# pooler host but CANNOT reach the direct :5432 host, so on Vercel
# you MUST use the pooler (never the direct :5432 connection).
# Use the Transaction-mode pooler with `pgbouncer=true`: this makes
# Prisma disable server-side prepared statements, which prevents the
# "prepared statement already exists / does not exist" (PgBouncer)
# errors. (Session-mode pooler also works and does not need pgbouncer=true.)
# Get the exact string from Supabase Dashboard -> Connect -> Pooler (6543).
DATABASE_URL="postgresql://postgres.xxiqfoghxbozycuxsqpr:YOUR_DB_PASSWORD@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=20&connect_timeout=30"
# Migrations / schema changes ONLY: the direct connection (port 5432).
# Reachable from your local machine / CI, but NOT from Vercel's runtime.
DIRECT_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.xxiqfoghxbozycuxsqpr.supabase.co:5432/postgres?sslmode=require"

# ---- Admin auth ----
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"
AUTH_SECRET="change-me-to-a-long-random-string-please-32chars+"

# ---- Image uploads ----
# Vercel Blob connected store: no token required.
# Vercel automatically sets BLOB_STORE_ID when the Blob integration is attached to the project.
